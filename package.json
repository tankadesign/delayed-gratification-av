		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/node": "^25.8.0",
		"@types/three": "^0.184.1",
		"@typescript-eslint/eslint-plugin": "^8.59.3",
		"@typescript-eslint/parser": "^8.59.3",
		"eslint": "^10.3.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.1",
		"firebase": "^12.13.0",
		"gsap": "^3.15.0",
		"pixi.js": "^8.18.1",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.2",
		"svelte": "^5.55.5",
		"svelte-check": "^4.4.8",
		"three": "^0.184.0",
